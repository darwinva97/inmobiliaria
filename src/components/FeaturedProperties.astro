---
import PropertyCard from './PropertyCard.astro';

const properties = [
  {
    image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=80',
    badge: 'sale' as const,
    price: 'USD 285,000',
    title: 'Departamento Premium en Miraflores',
    location: 'Miraflores, Lima',
    beds: 3, baths: 2, area: '120 m²', parking: true,
    slug: '/propiedades/departamento-miraflores',
  },
  {
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80',
    badge: 'sale' as const,
    price: 'USD 450,000',
    title: 'Casa Moderna en La Molina',
    location: 'La Molina, Lima',
    beds: 4, baths: 3, area: '250 m²', parking: true,
    slug: '/propiedades/casa-la-molina',
  },
  {
    image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80',
    badge: 'rent' as const,
    price: 'USD 1,800/mes',
    title: 'Penthouse con Vista al Mar',
    location: 'Barranco, Lima',
    beds: 2, baths: 2, area: '95 m²', parking: true,
    slug: '/propiedades/departamento-miraflores',
  },
  {
    image: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=600&q=80',
    badge: 'sale' as const,
    price: 'USD 195,000',
    title: 'Departamento Céntrico',
    location: 'San Isidro, Lima',
    beds: 2, baths: 1, area: '85 m²', parking: true,
    slug: '/propiedades/departamento-miraflores',
  },
  {
    image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=80',
    badge: 'sale' as const,
    price: 'USD 95,000',
    title: 'Departamento Familiar en Surco',
    location: 'Surco, Lima',
    beds: 3, baths: 2, area: '110 m²', parking: false,
    slug: '/propiedades/departamento-miraflores',
  },
  {
    image: 'https://images.unsplash.com/photo-1600573472592-401b489a3cdc?w=600&q=80',
    badge: 'rent' as const,
    price: 'USD 1,200/mes',
    title: 'Flat Moderno en San Borja',
    location: 'San Borja, Lima',
    beds: 1, baths: 1, area: '65 m²', parking: true,
    slug: '/propiedades/departamento-miraflores',
  },
];
---
<section class="section" id="propiedades">
  <div class="container">
    <div class="section-header">
      <h2>Propiedades Destacadas</h2>
      <p>Explora nuestra selección de las mejores propiedades en los distritos más exclusivos de Lima</p>
      <span class="accent-line"></span>
    </div>
    <div class="grid grid-3">
      {properties.map(p => <PropertyCard {...p} />)}
    </div>
    <div class="text-center mt-4">
      <a href="/propiedades" class="btn btn-outline">Ver Todas las Propiedades &rarr;</a>
    </div>
  </div>
</section>
