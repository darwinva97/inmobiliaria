<section class="section" id="contacto">
  <div class="container">
    <div class="section-header">
      <h2>Contáctanos</h2>
      <p>Estamos listos para ayudarte a encontrar la propiedad perfecta</p>
      <span class="accent-line"></span>
    </div>
    <div class="contact-grid">
      <div class="contact-form-wrap">
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre completo</label>
              <input type="text" class="form-control" placeholder="Tu nombre" />
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" class="form-control" placeholder="tu@email.com" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Teléfono</label>
              <input type="tel" class="form-control" placeholder="+51 999 999 999" />
            </div>
            <div class="form-group">
              <label>Tipo de propiedad</label>
              <select class="form-control">
                <option value="">Seleccionar</option>
                <option>Departamento</option>
                <option>Casa</option>
                <option>Oficina</option>
                <option>Terreno</option>
                <option>Local Comercial</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Presupuesto aproximado</label>
            <select class="form-control">
              <option value="">Seleccionar rango</option>
              <option>Hasta $50,000</option>
              <option>$50,000 - $100,000</option>
              <option>$100,000 - $200,000</option>
              <option>$200,000 - $350,000</option>
              <option>$350,000 - $500,000</option>
              <option>Más de $500,000</option>
            </select>
          </div>
          <div class="form-group">
            <label>Mensaje</label>
            <textarea class="form-control" rows="4" placeholder="Cuéntanos qué estás buscando..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">Enviar Mensaje</button>
        </form>
      </div>

      <div class="contact-info-side">
        <div class="map-placeholder">
          <div class="map-inner">
            <span>&#128205;</span>
            <p>Av. Javier Prado Este 2456<br/>San Isidro, Lima 15036</p>
          </div>
        </div>

        <div class="info-cards">
          <div class="info-card">
            <span class="info-icon">&#128205;</span>
            <div>
              <strong>Oficina Principal</strong>
              <p>Av. Javier Prado Este 2456, San Isidro, Lima</p>
            </div>
          </div>
          <div class="info-card">
            <span class="info-icon">&#128222;</span>
            <div>
              <strong>Teléfono</strong>
              <p>+51 1 625 8900</p>
            </div>
          </div>
          <div class="info-card">
            <span class="info-icon">&#128231;</span>
            <div>
              <strong>Email</strong>
              <p>info@inmovista.pe</p>
            </div>
          </div>
          <div class="info-card">
            <span class="info-icon">&#128337;</span>
            <div>
              <strong>Horario</strong>
              <p>Lun - Sáb: 9:00 - 19:00</p>
            </div>
          </div>
        </div>

        <a href="https://wa.me/5116258900" class="btn btn-whatsapp btn-lg" style="width:100%;justify-content:center;" target="_blank" rel="noopener">
          &#128172; Chatea por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

